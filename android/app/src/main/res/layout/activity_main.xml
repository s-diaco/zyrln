<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/title" />

            <TextView
                android:id="@+id/versionTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="12sp"
                android:textDirection="ltr"
                android:textColor="@color/subtitle" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnTheme"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_moon"
            android:tint="@color/icon"
            android:scaleType="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/btnLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/icon"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_tagline"
        android:textSize="13sp"
        android:textAlignment="viewStart"
        android:textColor="@color/subtitle"
        android:layout_marginBottom="24dp" />

    <!-- Status card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <View
                android:id="@+id/statusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/status_dot"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/status_stopped"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/title" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Config list -->
    <ScrollView
        android:id="@+id/configScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/configList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Empty state -->
    <TextView
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="@string/empty_configs"
        android:textSize="15sp"
        android:textColor="@color/subtitle"
        android:visibility="visible" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnImportConfig"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_import_config"
        android:textSize="15sp"
        android:textAllCaps="false"
        app:cornerRadius="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Install CA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnInstallCA"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="@string/btn_install_ca"
        android:textSize="14sp"
        android:textAllCaps="false"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ca_install_hint"
        android:textSize="12sp"
        android:textColor="@color/subtitle"
        android:gravity="center" />

</LinearLayout>
